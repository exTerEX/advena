/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    advena Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // ──────────────────────────────────────────────
    // Input / output
    // ──────────────────────────────────────────────
    input = null
    outdir = "results"
    // ──────────────────────────────────────────────
    // ICEscreen
    // ──────────────────────────────────────────────
    phylum = "bacillota" // taxonomic phylum (currently only "bacillota")
    codon_table = 11 // genetic code for CDS translation
    icescreen_root = System.getenv("ICESCREEN_ROOT") ?: "/opt/conda/bin" // path to ICEscreen installation
    icescreen_db = null // optional override path to pre-indexed databases
    // ──────────────────────────────────────────────
    // BLAST parameters
    // ──────────────────────────────────────────────
    blastp_evalue = 0.001
    blastp_max_target_seqs = 10
    // ──────────────────────────────────────────────
    // ME detection parameters
    // ──────────────────────────────────────────────
    min_cds_between_segments = 100
    max_cds_for_ime_size = 10
    // ──────────────────────────────────────────────
    // Nextflow internals
    // ──────────────────────────────────────────────
    publish_dir_mode = "copy" // copy | symlink | move | rellink | link
    monochrome_logs = false
    help = false
    version = false
}

// Load base resource config
includeConfig "conf/base.config"

// Load module-level publishDir configuration
includeConfig "conf/modules.config"

// Execution profiles
profiles {
    debug {
        process.beforeScript = "echo $HOSTNAME"
    }
    // ── Container engines ──────────────────────────
    docker {
        docker.enabled = true
        docker.runOptions = "-u \$(id -u):\$(id -g)"
        singularity.enabled = false
        conda.enabled = false
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        conda.enabled = false
    }
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        docker.enabled = false
        singularity.enabled = false
        conda.enabled = false
    }
    podman {
        podman.enabled = true
        docker.enabled = false
        singularity.enabled = false
        conda.enabled = false
    }
    // ── Software environments ──────────────────────
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
    }
    // ── Test profiles ─────────────────────────────
    test {
        includeConfig "conf/test.config"
    }
    // ── HPC / cluster ─────────────────────────────
    hpc {
        process {
            resourceLimits = [cpus: 64, memory: 256.GB, time: 720.h]
        }
    }
    slurm {
        process {
            executor = "slurm"
            resourceLimits = [cpus: 64, memory: 256.GB, time: 720.h]
        }
    }
}

process.shell = ["/bin/bash", "-euo", "pipefail"]

// Capture pipeline execution metadata
def trace_timestamp = new java.util.Date().format("yyyy-MM-dd_HH-mm-ss")
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html"
}

manifest {
    name = "exterex/advena"
    author = "Andreas Sagen"
    homePage = "https://github.com/exterex/advena"
    description = "Nextflow pipeline for ICEscreen: detection and annotation of ICEs and IMEs in Bacillota genomes"
    mainScript = "main.nf"
    nextflowVersion = "!>=23.04.0"
    version = "1.0.0"
}
